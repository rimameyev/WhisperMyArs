<Window x:Class="WhisperMyArs.UI.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="WhisperMyArs — Settings"
        Width="500" Height="660" MinWidth="440" MinHeight="420"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        Background="#1B1B1F"
        TextElement.Foreground="#EDEDF2"
        FontFamily="Segoe UI" FontSize="13">

    <Window.Resources>
        <SolidColorBrush x:Key="Panel" Color="#26262C"/>
        <SolidColorBrush x:Key="Accent" Color="#6E9BFF"/>
        <SolidColorBrush x:Key="Sub" Color="#9A9AA5"/>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#EDEDF2"/>
        </Style>

        <Style x:Key="Header" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource Sub}"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#15151A"/>
            <Setter Property="Foreground" Value="#EDEDF2"/>
            <Setter Property="BorderBrush" Value="#3A3A44"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="CaretBrush" Value="#EDEDF2"/>
        </Style>

        <Style TargetType="PasswordBox">
            <Setter Property="Background" Value="#15151A"/>
            <Setter Property="Foreground" Value="#EDEDF2"/>
            <Setter Property="BorderBrush" Value="#3A3A44"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="CaretBrush" Value="#EDEDF2"/>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#EDEDF2"/>
            <Setter Property="Margin" Value="0,6,0,0"/>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Background" Value="#2E2E36"/>
            <Setter Property="Foreground" Value="#EDEDF2"/>
            <Setter Property="BorderBrush" Value="#3A3A44"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="18,9"/>
            <Setter Property="MinWidth" Value="84"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="Primary" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="{StaticResource Accent}"/>
            <Setter Property="Foreground" Value="#0E0E12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

        <Style TargetType="ListBox">
            <Setter Property="Background" Value="#15151A"/>
            <Setter Property="Foreground" Value="#EDEDF2"/>
            <Setter Property="BorderBrush" Value="#3A3A44"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <!-- Slim dark scrollbar -->
        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Width" Value="10"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Border Background="#15151A" CornerRadius="5">
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Background="#3A3A44" CornerRadius="5" Margin="2,0"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageDownCommand" Opacity="0" Focusable="False"/>
                                </Track.IncreaseRepeatButton>
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageUpCommand" Opacity="0" Focusable="False"/>
                                </Track.DecreaseRepeatButton>
                            </Track>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="0,0,8,0">
        <StackPanel>

        <!-- API profiles -->
        <Border Background="{StaticResource Panel}" CornerRadius="10" Padding="16" Margin="0,0,0,14">
            <StackPanel>
                <TextBlock Style="{StaticResource Header}" Text="API PROFILES"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <ListBox x:Name="ProfilesList" Height="92" SelectionChanged="ProfilesList_SelectionChanged"/>
                    <StackPanel Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Top">
                        <Button Content="Add" Click="AddProfile_Click" Margin="0,0,0,6"/>
                        <Button Content="Remove" Click="RemoveProfile_Click"/>
                    </StackPanel>
                </Grid>

                <StackPanel x:Name="ProfileEditor" Margin="0,12,0,0" IsEnabled="False">
                    <TextBlock Text="Name" Foreground="{StaticResource Sub}" Margin="0,0,0,2"/>
                    <TextBox x:Name="NameBox" TextChanged="ProfileField_Changed"/>
                    <TextBlock Text="API key" Foreground="{StaticResource Sub}" Margin="0,8,0,2"/>
                    <PasswordBox x:Name="KeyBox" PasswordChanged="KeyBox_Changed"/>
                    <TextBlock Text="Transcription URL" Foreground="{StaticResource Sub}" Margin="0,8,0,2"/>
                    <TextBox x:Name="UrlBox" TextChanged="ProfileField_Changed"/>
                    <TextBlock Text="Model" Foreground="{StaticResource Sub}" Margin="0,8,0,2"/>
                    <TextBox x:Name="ModelBox" TextChanged="ProfileField_Changed"/>
                    <CheckBox x:Name="ActiveCheck" Content="Use this profile (active)" Checked="ActiveCheck_Changed" Unchecked="ActiveCheck_Changed"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Engine -->
        <Border Background="{StaticResource Panel}" CornerRadius="10" Padding="16" Margin="0,0,0,14">
            <StackPanel>
                <TextBlock Style="{StaticResource Header}" Text="TRANSCRIPTION ENGINE"/>
                <RadioButton x:Name="RemoteRadio" GroupName="Engine" Foreground="#EDEDF2"
                             Content="Remote — Groq Whisper API (needs internet)"/>
                <RadioButton x:Name="LocalRadio" GroupName="Engine" Foreground="#EDEDF2" Margin="0,6,0,0"
                             Content="Local — Parakeet v3, offline (no internet needed)"/>
                <CheckBox x:Name="FallbackCheck" Margin="0,8,0,0"
                          Content="If online transcription fails, fall back to the local model"/>

                <Border Background="#15151A" CornerRadius="6" Padding="10" Margin="0,12,0,0">
                    <StackPanel>
                        <TextBlock x:Name="ModelStatusText" Text="Local model: checking…" Foreground="{StaticResource Sub}"/>
                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                            <Button x:Name="DownloadBtn" Content="Download offline model (~465 MB)" Click="DownloadBtn_Click"/>
                            <Button x:Name="RemoveModelBtn" Content="Remove" Margin="8,0,0,0" Click="RemoveModelBtn_Click"/>
                        </StackPanel>
                        <ProgressBar x:Name="DownloadBar" Height="6" Margin="0,10,0,0" Minimum="0" Maximum="100"
                                     Foreground="{StaticResource Accent}" Background="#2E2E36" BorderThickness="0"
                                     Visibility="Collapsed"/>
                        <TextBlock x:Name="DownloadStatus" Foreground="{StaticResource Sub}" FontSize="11" Margin="0,4,0,0"
                                   Visibility="Collapsed"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>

        <!-- Hotkey -->
        <Border Background="{StaticResource Panel}" CornerRadius="10" Padding="16" Margin="0,0,0,14">
            <StackPanel>
                <TextBlock Style="{StaticResource Header}" Text="ACTIVATION"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Border Background="#15151A" CornerRadius="6" Padding="8,6" BorderBrush="#3A3A44" BorderThickness="1">
                        <TextBlock x:Name="HotkeyText" Text="—" VerticalAlignment="Center"/>
                    </Border>
                    <Button Grid.Column="1" x:Name="CaptureBtn" Content="Set hotkey" Margin="10,0,0,0" Click="CaptureBtn_Click"/>
                </Grid>
                <CheckBox x:Name="MiddleMouseCheck" Content="Also use mouse middle button"/>
            </StackPanel>
        </Border>

        <!-- General -->
        <Border Background="{StaticResource Panel}" CornerRadius="10" Padding="16" Margin="0,0,0,14">
            <StackPanel>
                <TextBlock Style="{StaticResource Header}" Text="GENERAL"/>
                <CheckBox x:Name="StartupCheck" Content="Run on Windows startup (hidden to tray)"/>
                <CheckBox x:Name="SoundsCheck" Content="Play start/stop sounds"/>
            </StackPanel>
        </Border>

        </StackPanel>
        </ScrollViewer>

        <TextBlock Grid.Row="1" TextWrapping="Wrap" Margin="0,10,0,0"
                   Foreground="{StaticResource Sub}" FontSize="11"
                   Text="Toggle the hotkey to start/stop dictation. Press Esc to cancel. Transcribed text is pasted into the focused field. WhisperMyArs keeps running in the system tray — closing this window does not quit it (use the tray menu to quit)."/>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Close" Click="Close_Click" Margin="0,0,8,0"/>
            <Button Content="Save" Style="{StaticResource Primary}" Click="Save_Click"/>
        </StackPanel>
    </Grid>
</Window>
